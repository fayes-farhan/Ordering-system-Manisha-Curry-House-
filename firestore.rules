rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Menu categories - public read, allow write for automatic database seeding
    match /menu_categories/{categoryId} {
      allow read, write: if true;
    }

    // Menu subcategories - public read, allow write for automatic database seeding
    match /menu_subcategories/{subcategoryId} {
      allow read, write: if true;
    }

    // Menu items - public read, allow write for automatic database seeding
    match /menu_items/{itemId} {
      allow read, write: if true;
    }

    // Orders - guests can create orders and get a specific order by ID to see confirmation, but never list or update them
    match /orders/{orderId} {
      allow get: if true;
      allow list: if false;
      allow create: if isValidOrder(request.resource.data);
      allow update, delete: if false; // Strict immutability once confirmed at Mamak counter
    }

    // Helper functions for order validation
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'tableSession', 'items', 'totalAmount', 'paymentMethod', 'status', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string
        && data.tableSession is string
        && data.tableSession.size() > 0
        && data.items is list
        && data.totalAmount is number
        && (data.paymentMethod == 'cash' || data.paymentMethod == 'qr')
        && data.status == 'confirmed';
    }
  }
}
